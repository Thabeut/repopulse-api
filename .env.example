PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TIMEOUT_MS=10000
GITHUB_CACHE_TTL_SECONDS=120
SYNC_ENABLED=true
SYNC_CRON=0 */6 * * *
SYNC_CONCURRENCY=2
SYNC_MIN_INTERVAL_MINUTES=30
SNAPSHOT_RETENTION=90
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
AUTH_ALLOW_DEV_HEADER=true
